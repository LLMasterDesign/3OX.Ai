// doc:[COMPLETE] modified:[26.03.03] auth:[3OX.AI]
// Compile and run Vec3Boot via Bun

import { $ } from "bun";

console.log("Building Vec3Boot boot project...");
await $`cd boot && cargo build --release`;

console.log("Running vec3-boot executable...");
const args = process.argv.slice(2);
if (args.length > 0) {
  await $`./boot/target/release/vec3-boot ${args.join(' ')}`;
} else {
  await $`./boot/target/release/vec3-boot`;
}

// :: ∎
