# Speaker mesh — LLM inference and agent processing

[Unit]
Description=3OX Speaker Mesh — Agent LLM Processing
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/!CMD.VPS/TelePromptR
ExecStart=/usr/bin/ruby tools/speaker_mesh.rb
Restart=always
RestartSec=5
TimeoutStopSec=15
Environment=LANG=en_US.UTF-8

[Install]
WantedBy=multi-user.target
